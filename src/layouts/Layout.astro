---
import { translations } from '../data/translations';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  lang?: 'en' | 'ms' | 'zh';
  title?: string;
  description?: string;
}

const currentLocale = Astro.currentLocale as 'en' | 'ms' | 'zh' || 'en';
const { lang = currentLocale, title, description } = Astro.props;
const t = translations[lang];

const pageTitle = title || t.meta.title;
const pageDesc = description || t.meta.description;

// SEO Constants
const siteUrl = 'https://jgrcivilworks.com'; // Change to final domain
const canonicalUrl = lang === 'en' ? siteUrl : `${siteUrl}/${lang}`;

// Setup dynamic JSON-LD Schema
const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HomeAndConstructionBusiness",
      "@id": `${siteUrl}/#organization`,
      "name": "JGR Civil Works",
      "url": siteUrl,
      "logo": `${siteUrl}/logo.png`,
      "image": `${siteUrl}/hero-cover.jpg`,
      "telephone": "+6012-345 6789",
      "email": "contact@jgrcivilworks.com",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "15, Jalan Industry 2/3, Taman Perindustrian Kepong",
        "addressLocality": "Kepong",
        "addressRegion": "Kuala Lumpur",
        "postalCode": "52100",
        "addressCountry": "MY"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 3.2128,
        "longitude": 101.6375
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "08:00",
          "closes": "18:00"
        }
      ],
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Kuala Lumpur" },
        { "@type": "AdministrativeArea", "name": "Selangor" },
        { "@type": "AdministrativeArea", "name": "Klang Valley" }
      ]
    },
    {
      "@type": "Service",
      "@id": `${siteUrl}/#service-roofing`,
      "provider": { "@id": `${siteUrl}/#organization` },
      "name": t.core4.services[0].title,
      "description": t.core4.services[0].description,
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Kuala Lumpur" },
        { "@type": "AdministrativeArea", "name": "Selangor" }
      ]
    },
    {
      "@type": "Service",
      "@id": `${siteUrl}/#service-plumbing`,
      "provider": { "@id": `${siteUrl}/#organization` },
      "name": t.core4.services[1].title,
      "description": t.core4.services[1].description,
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Kuala Lumpur" },
        { "@type": "AdministrativeArea", "name": "Selangor" }
      ]
    },
    {
      "@type": "Service",
      "@id": `${siteUrl}/#service-electrical`,
      "provider": { "@id": `${siteUrl}/#organization` },
      "name": t.core4.services[2].title,
      "description": t.core4.services[2].description,
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Kuala Lumpur" },
        { "@type": "AdministrativeArea", "name": "Selangor" }
      ]
    },
    {
      "@type": "Service",
      "@id": `${siteUrl}/#service-handyman`,
      "provider": { "@id": `${siteUrl}/#organization` },
      "name": t.core4.services[3].title,
      "description": t.core4.services[3].description,
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Kuala Lumpur" },
        { "@type": "AdministrativeArea", "name": "Selangor" }
      ]
    }
  ]
};
---

<!doctype html>
<html lang={t.langCode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary SEO Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="keywords" content={t.meta.keywords} />
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Multilingual Hreflang Tags (Crucial for Local SEO) -->
    <link rel="alternate" hreflang="en" href={siteUrl} />
    <link rel="alternate" hreflang="ms" href={`${siteUrl}/ms`} />
    <link rel="alternate" hreflang="zh" href={`${siteUrl}/zh`} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:image" content={`${siteUrl}/hero-cover.jpg`} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDesc} />
    <meta property="twitter:image" content={`${siteUrl}/hero-cover.jpg`} />

    <!-- Schema Markup JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    
    <ClientRouter />
  </head>
  <body>
    <slot />

    <script>
      // Intersection Observer for scroll animation reveals
      function setupScrollAnimations() {
        const revealElements = document.querySelectorAll('.reveal');
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.1,
          rootMargin: '0px 0px -40px 0px'
        });

        revealElements.forEach(el => observer.observe(el));
      }

      // Initial load
      setupScrollAnimations();

      // Re-run animation hooks after Astro View Transitions swap the page content
      document.addEventListener('astro:after-swap', setupScrollAnimations);
    </script>
  </body>
</html>
