---
import { translations } from '../data/translations';

interface Props {
  lang: 'en' | 'ms' | 'zh';
}

const { lang } = Astro.props;
const t = translations[lang];

// Lang mapping helper
const locales = [
  { code: 'en', label: 'English', path: '/' },
  { code: 'ms', label: 'B. Melayu', path: '/ms' },
  { code: 'zh', label: '简体中文', path: '/zh' }
];
---

<header class="site-header">
  <div class="container header-container">
    <a href={lang === 'en' ? '/' : `/${lang}`} class="logo-area">
      <div class="logo-icon">JGR</div>
      <div class="logo-text">
        <span class="logo-title">JGR CIVIL WORKS</span>
        <span class="logo-subtitle">Contracting & Maintenance</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav" aria-label="Main Navigation">
      <a href="#services">{t.nav.services}</a>
      <a href="#secondary">{t.nav.secondary}</a>
      <a href="#why-choose-us">{t.nav.about}</a>
      <a href="#gallery">{t.nav.gallery}</a>
      <a href="#contact">{t.nav.contact}</a>
    </nav>

    <!-- Language Selector + Contact CTA -->
    <div class="header-actions">
      <!-- Language Switcher Dropdown -->
      <div class="lang-switcher">
        <button class="lang-btn" aria-haspopup="listbox" aria-expanded="false" id="lang-menu-button">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          {locales.find(l => l.code === lang)?.label}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <ul class="lang-dropdown" role="listbox" aria-labelledby="lang-menu-button">
          {locales.map(l => (
            <li role="option" aria-selected={l.code === lang ? "true" : "false"}>
              <a href={l.path} class={l.code === lang ? 'active' : ''}>{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Call CTA -->
      <a href="tel:+60123456789" class="btn btn-secondary call-header-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>+60 12-345 6789</span>
      </a>

      <!-- Hamburger mobile Menu Button -->
      <button class="mobile-menu-toggle" aria-label="Toggle Menu" aria-expanded="false">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer Menu -->
  <div class="mobile-drawer">
    <nav class="mobile-nav">
      <a href="#services" class="mobile-link">{t.nav.services}</a>
      <a href="#secondary" class="mobile-link">{t.nav.secondary}</a>
      <a href="#why-choose-us" class="mobile-link">{t.nav.about}</a>
      <a href="#gallery" class="mobile-link">{t.nav.gallery}</a>
      <a href="#contact" class="mobile-link">{t.nav.contact}</a>
      <div class="divider"></div>
      <div class="mobile-lang-list">
        {locales.map(l => (
          <a href={l.path} class={l.code === lang ? 'active' : ''}>{l.label}</a>
        ))}
      </div>
      <a href="tel:+60123456789" class="btn btn-primary mobile-call-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {t.nav.callNow}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--header-height);
    background-color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    z-index: 1000;
    transition: var(--transition-normal);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .logo-area {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    background: var(--color-accent-gradient);
    color: white;
    font-weight: 800;
    font-size: 1.1rem;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    letter-spacing: 1px;
    box-shadow: var(--shadow-sm);
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .logo-title {
    font-family: var(--font-header);
    font-weight: 800;
    font-size: 1.15rem;
    letter-spacing: 0.5px;
    color: var(--color-primary);
  }

  .logo-subtitle {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Navigation styling */
  .desktop-nav {
    display: flex;
    gap: 28px;
  }

  .desktop-nav a {
    font-family: var(--font-header);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary-light);
    position: relative;
    padding: 8px 0;
  }

  .desktop-nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent-gradient);
    transition: var(--transition-fast);
  }

  .desktop-nav a:hover {
    color: var(--color-accent);
  }

  .desktop-nav a:hover::after {
    width: 100%;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .call-header-btn {
    padding: 8px 18px;
    font-size: 0.9rem;
    border-radius: var(--radius-sm);
  }

  /* Lang Switcher Styling */
  .lang-switcher {
    position: relative;
  }

  .lang-btn {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 8px 14px;
    font-family: var(--font-header);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--color-primary-light);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: var(--transition-fast);
  }

  .lang-btn:hover {
    background-color: var(--color-bg-alt);
    border-color: var(--color-text-muted);
  }

  .lang-btn svg {
    color: var(--color-accent);
  }

  .lang-btn svg.chevron {
    color: var(--color-text-muted);
    transition: var(--transition-fast);
  }

  .lang-switcher:hover .lang-btn svg.chevron {
    transform: rotate(180deg);
  }

  .lang-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 6px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-lg);
    list-style: none;
    width: 130px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: var(--transition-normal);
    z-index: 1010;
    padding: 6px 0;
  }

  .lang-switcher:hover .lang-dropdown,
  .lang-switcher:focus-within .lang-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-dropdown li a {
    display: block;
    padding: 8px 16px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary-light);
  }

  .lang-dropdown li a:hover,
  .lang-dropdown li a.active {
    background-color: var(--color-bg-alt);
    color: var(--color-accent);
  }

  /* Hamburger Menu Styling */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 1100;
  }

  .mobile-menu-toggle .bar {
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    transition: var(--transition-normal);
  }

  .mobile-menu-toggle.open .bar:nth-child(1) {
    transform: rotate(45deg) translate(5px, 6px);
  }

  .mobile-menu-toggle.open .bar:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.open .bar:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -6px);
  }

  /* Mobile Drawer Styling */
  .mobile-drawer {
    position: fixed;
    top: var(--header-height);
    left: 0;
    width: 100%;
    height: calc(100vh - var(--header-height));
    background-color: white;
    z-index: 999;
    transform: translateX(100%);
    transition: var(--transition-normal);
    border-top: 1px solid var(--color-border);
    padding: 30px;
    box-shadow: var(--shadow-lg);
    overflow-y: auto;
  }

  .mobile-drawer.open {
    transform: translateX(0);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .mobile-nav a.mobile-link {
    font-family: var(--font-header);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-primary);
    padding-bottom: 5px;
    border-bottom: 1px solid var(--color-bg-alt);
  }

  .mobile-nav .divider {
    height: 1px;
    background-color: var(--color-border);
    margin: 10px 0;
  }

  .mobile-lang-list {
    display: flex;
    gap: 15px;
    margin-bottom: 10px;
  }

  .mobile-lang-list a {
    font-weight: 600;
    font-size: 0.95rem;
    padding: 6px 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
  }

  .mobile-lang-list a.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background-color: hsl(var(--color-accent-hue), 100%, 97%);
  }

  .mobile-call-btn {
    margin-top: 15px;
    font-size: 1.1rem;
    width: 100%;
  }

  @media (max-width: 991px) {
    .desktop-nav, .call-header-btn {
      display: none;
    }
    .mobile-menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  // Script is safe to run in SSR pages and is executing only on the client
  const toggleBtn = document.querySelector('.mobile-menu-toggle');
  const drawer = document.querySelector('.mobile-drawer');
  const links = document.querySelectorAll('.mobile-link');
  const header = document.querySelector('.site-header');

  if (toggleBtn && drawer) {
    toggleBtn.addEventListener('click', () => {
      const isOpen = toggleBtn.classList.toggle('open');
      drawer.classList.toggle('open');
      toggleBtn.setAttribute('aria-expanded', String(isOpen));
    });

    links.forEach(link => {
      link.addEventListener('click', () => {
        toggleBtn.classList.remove('open');
        drawer.classList.remove('open');
        toggleBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Scroll effect on header
  window.addEventListener('scroll', () => {
    if (header) {
      if (window.scrollY > 50) {
        header.style.backgroundColor = 'rgba(255, 255, 255, 0.98)';
        header.style.boxShadow = 'var(--shadow-sm)';
        header.style.height = '70px';
      } else {
        header.style.backgroundColor = 'rgba(255, 255, 255, 0.9)';
        header.style.boxShadow = 'none';
        header.style.height = 'var(--header-height)';
      }
    }
  });
</script>
