---
interface Props {
  videoId: string;
  title: string;
}

const { videoId, title } = Astro.props;
const thumbnailUrl = `https://i3.ytimg.com/vi/${videoId}/hqdefault.jpg`;
---

<div class="youtube-lite" data-id={videoId} data-title={title}>
  <!-- Placeholder thumbnail -->
  <img 
    src={thumbnailUrl} 
    alt={`Video thumbnail for: ${title}`} 
    loading="lazy" 
    width="480"
    height="360"
    class="youtube-thumb"
  />
  
  <!-- Play button overlay -->
  <button class="youtube-play-btn" aria-label={`Play video: ${title}`}>
    <svg viewBox="0 0 68 48" width="68" height="48" xmlns="http://www.w3.org/2000/svg">
      <path class="play-btn-bg" d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.06 0 24 0 24s.06 10.94 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.94 68 24 68 24s-.06-10.94-1.48-16.26z" fill="#f00" fill-opacity="0.85"/>
      <polygon points="26,15 44,24 26,33" fill="#fff"/>
    </svg>
  </button>
</div>

<style>
  .youtube-lite {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #000;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
    transition: var(--transition-normal);
  }

  .youtube-lite:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-lg);
  }

  .youtube-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter var(--transition-normal);
  }

  .youtube-lite:hover .youtube-thumb {
    filter: brightness(0.85);
  }

  .youtube-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: pointer;
    z-index: 2;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--transition-fast) ease-out;
  }

  .youtube-play-btn svg {
    filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.3));
  }

  .youtube-play-btn svg .play-btn-bg {
    transition: fill var(--transition-fast);
  }

  .youtube-lite:hover .youtube-play-btn {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .youtube-lite:hover .youtube-play-btn svg .play-btn-bg {
    fill: #ff0000;
    fill-opacity: 1;
  }

  /* Iframe styling when generated dynamically */
  .youtube-lite iframe {
    width: 100%;
    height: 100%;
    border: none;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 3;
  }
</style>

<script>
  // Safe client-only execution script to defer heavy iframe load
  const embeds = document.querySelectorAll('.youtube-lite');
  
  embeds.forEach(embed => {
    embed.addEventListener('click', function() {
      const videoId = this.getAttribute('data-id');
      const videoTitle = this.getAttribute('data-title') || 'YouTube Video';
      
      if (videoId && !this.querySelector('iframe')) {
        const iframe = document.createElement('iframe');
        iframe.setAttribute('src', `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`);
        iframe.setAttribute('title', videoTitle);
        iframe.setAttribute('frameborder', '0');
        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
        iframe.setAttribute('allowfullscreen', 'true');
        
        // Clear thumb and button, render iframe
        this.innerHTML = '';
        this.appendChild(iframe);
      }
    }, { once: true }); // Bind listener once
  });
</script>
