---
import { translations } from '../data/translations';

interface Props {
  lang: 'en' | 'ms' | 'zh';
}

const { lang } = Astro.props;
const t = translations[lang];

// Setup WhatsApp helper function
const getWhatsAppUrl = (msg?: any) => {
  return 'https://webjgrcw.wasap.my';
};

// Setup localized URL routing
const getServiceUrl = (slug: string) => {
  if (lang === 'en') return `/services/${slug}`;
  return `/${lang}/services/${slug}`;
};

// Localized action tags
const viewDetailsText = {
  en: 'Learn More & View Details',
  ms: 'Ketahui Lebih Lanjut',
  zh: '了解服务详情与案例'
}[lang];
---

<section id="services" class="section">
  <div class="container">
    <div class="text-center reveal">
      <span class="badge">{t.nav.services}</span>
      <h2 class="section-title">{t.core4.title}</h2>
      <p class="section-subtitle">{t.core4.subtitle}</p>
    </div>

    <div class="grid-2 services-grid">
      {t.core4.services.map((service, index) => (
        <article class={`service-card reveal delay-${(index + 1) * 100}`} id={`card-${service.id}`}>
          <div class="card-header-flex">
            <!-- Dynamic SVG Icons based on ID -->
            <div class="service-icon-wrapper">
              {service.id === 'roofing' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <path d="M12 22V12"/>
                  <path d="m9 15 3-3 3 3"/>
                  <path d="M17 19v.01"/>
                  <path d="M7 19v.01"/>
                </svg>
              )}
              {service.id === 'plumbing' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22a7 7 0 0 0 7-7c0-4.3-7-11-7-11S5 10.7 5 15a7 7 0 0 0 7 7z"/>
                  <path d="M12 18a3 3 0 0 0 3-3"/>
                </svg>
              )}
              {service.id === 'electrical' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                </svg>
              )}
              {service.id === 'handyman' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
              )}
            </div>
            <h3 class="service-title">{service.title}</h3>
          </div>

          <p class="service-desc">{service.description}</p>

          <!-- Core detailed items list -->
          <ul class="service-details-list">
            {service.details.slice(0, 3).map((detail) => (
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><path d="M20 6 9 17l-5-5"/></svg>
                <span>{detail}</span>
              </li>
            ))}
          </ul>

          <!-- Local search SEO tags embedded for index crawlability -->
          <div class="seo-keywords-tagline" aria-hidden="true">
            <strong>Targeted:</strong> {service.keywords.join(', ')}
          </div>

          <!-- Dual action buttons: View Details & WhatsApp -->
          <div class="card-action-buttons">
            <a href={getServiceUrl(service.slug)} class="btn btn-secondary action-btn view-details-btn">
              <span>{viewDetailsText}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            
            {service.id === 'roofing' && (
              <a href={getWhatsAppUrl(t.whatsappMsg.roof)} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp action-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>WhatsApp</span>
              </a>
            )}
            {service.id === 'plumbing' && (
              <a href={getWhatsAppUrl(t.whatsappMsg.plumbing)} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp action-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>WhatsApp</span>
              </a>
            )}
            {service.id === 'electrical' && (
              <a href={getWhatsAppUrl(t.whatsappMsg.electrical)} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp action-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>WhatsApp</span>
              </a>
            )}
            {service.id === 'handyman' && (
              <a href={getWhatsAppUrl(t.whatsappMsg.handyman)} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp action-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>WhatsApp</span>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    margin-top: 20px;
  }

  .service-card {
    background-color: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 40px;
    box-shadow: var(--shadow-sm);
    transition: var(--transition-normal);
    display: flex;
    flex-direction: column;
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent-light);
  }

  .card-header-flex {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 20px;
  }

  .service-icon-wrapper {
    background: var(--color-accent-gradient);
    color: white;
    width: 60px;
    height: 60px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: var(--shadow-accent);
  }

  .service-title {
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    font-weight: 750;
    color: var(--color-primary);
  }

  .service-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 30px;
    line-height: 1.5;
  }

  .service-details-list {
    list-style: none;
    margin-bottom: 30px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .service-details-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.95rem;
    color: var(--color-text-dark);
  }

  .check-icon {
    color: var(--color-success);
    margin-top: 3px;
    flex-shrink: 0;
  }

  .seo-keywords-tagline {
    display: none;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-alt);
    padding: 10px;
    border-radius: var(--radius-sm);
    margin-bottom: 20px;
  }

  /* Dual Action buttons spacing styles */
  .card-action-buttons {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 12px;
    margin-top: auto;
  }

  .action-btn {
    padding: 12px 16px;
    font-size: 0.875rem;
    border-radius: var(--radius-sm);
  }

  .view-details-btn {
    background-color: var(--color-bg-alt);
    border-color: var(--color-border);
    color: var(--color-primary-light);
  }

  .view-details-btn:hover {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  @media (max-width: 576px) {
    .card-action-buttons {
      grid-template-columns: 1fr;
      gap: 10px;
    }
  }
</style>
